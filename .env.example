# ─── Database ───────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, Railway, etc.)
DATABASE_URL=postgresql://user:password@host:5432/bundlyplus

# ─── Session ─────────────────────────────────────────────────
# Any long random string (e.g. openssl rand -base64 32)
SESSION_SECRET=replace_with_a_long_random_secret

# ─── Firebase ────────────────────────────────────────────────
# From Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=bundlyplus
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@bundlyplus.iam.gserviceaccount.com
# Paste the entire private key including -----BEGIN/END PRIVATE KEY-----
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Runtime (set automatically by most platforms) ───────────
NODE_ENV=production
PORT=3000
